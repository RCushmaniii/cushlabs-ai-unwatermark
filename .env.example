# Required for legacy Claude Vision detection (Layer 3 fallback)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required for Florence-2 detection (Layer 2 — recommended, ~$0.001/call)
REPLICATE_API_TOKEN=r8_your_token_here

# Optional: OpenAI Vision as alternative to Claude
# OPENAI_API_KEY=sk-your-key-here

# Optional: override detection provider (default: claude)
# UNWATERMARK_ANALYSIS_PROVIDER=claude

# Optional: override inpainting backend (default: local)
# UNWATERMARK_INPAINT_BACKEND=local
