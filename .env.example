# Required — Claude vision analysis
ANTHROPIC_API_KEY=sk-ant-...

# Optional — GPT-4o alternative
OPENAI_API_KEY=sk-...

# Optional — Replicate for SaaS inpainting
REPLICATE_API_TOKEN=r8_...

# Optional — provider overrides
# UNWATERMARK_ANALYSIS_PROVIDER=claude    # claude or openai
# UNWATERMARK_ANALYSIS_MODEL=claude-sonnet-4-20250514
# UNWATERMARK_INPAINT_BACKEND=local      # local, replicate, or modal
# UNWATERMARK_MODAL_ENDPOINT_URL=https://your-modal-endpoint.modal.run/inpaint
# UNWATERMARK_LAMA_MODEL_PATH=           # custom path to LaMa model weights
