# Required: Claude Vision detection (primary AI fallback)
ANTHROPIC_API_KEY=

# Required: Florence-2 + SAM detection via Replicate (~$0.001/call)
REPLICATE_API_TOKEN=

# Optional: OpenAI Vision as alternative to Claude
OPENAI_API_KEY=

# Detection provider (default: claude)
UNWATERMARK_ANALYSIS_PROVIDER=claude

# Inpainting backend: local | replicate (use replicate on VPS to save RAM)
UNWATERMARK_INPAINT_BACKEND=replicate
